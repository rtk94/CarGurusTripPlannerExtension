{
  "manifest_version": 3,
  "name": "CarGurus Trip Planner",
  "version": "1.2",
  "description": "Sync and visualize your saved CarGurus listings on an interactive map.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["*://*.cargurus.com/*"],
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard/dashboard.html", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
